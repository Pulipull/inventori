{
  "functions": {
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.3"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/api/index.php"
    }
  ],
  "env": {
    "LOG_CHANNEL": "stderr",
    "SESSION_DRIVER": "array",
    "VIEW_COMPILED_PATH": "/tmp",
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  }
}